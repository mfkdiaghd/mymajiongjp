.hide
    display: none !important
.fadeout
    opacity: 0 !important

input
textarea
    font-size: 100%
    font-family: fixed-font

button
    font-size: 100%

button
input[type="submit"]
input[type="reset"]
input[type="button"]
    font-family: menu-font
    padding: 1px 1em
    border: solid 1px
    border-radius: 4px
    background: #ddd
    color: black
    -webkit-appearance: none

input::placeholder
    color: #999
    opacity: 1

select
    border: solid 1px
    border-radius: 4px
    font-size: 100%
    padding: 1px
    background: #ddd
    color: black

@keyframes blink
    100%
        opacity: 0.7
@keyframes blink-text
    100%
        opacity: 0.2

body
    -webkit-text-size-adjust: 100%
    margin-top: 0

#loaddata
    display: none

[role="button"] *
    pointer-events: none
// 强制让游戏容器占满全屏
:global(.majiang)
    width: 100vw !important
    height: 100vh !important
    max-width: none !important
    max-height: none !important
    position: fixed !important
    top: 0
    left: 0
    margin: 0 !important
    z-index: 9999

// 隐藏顶部导航栏（如果你想要纯净的全屏游戏体验）
:global(.navi)
    display: none !important